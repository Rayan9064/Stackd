datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

model Article {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  summary     String?
  source      String
  sourceUrl   String
  geography   String?  // "US" | "EU" | "SEA" | "India" | "LATAM" | "Africa" | "Global"
  tags String
  publishedAt DateTime
  createdAt   DateTime @default(now())
}

model Launch {
  id          String   @id @default(cuid())
  title       String
  tagline     String?
  url         String   @unique
  sourceUrl   String
  source      String   // "ph" | "hn"
  upvotes     Int      @default(0)
  launchedAt  DateTime
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String?
  remote      Boolean  @default(false)
  equity      String?
  url         String   @unique
  sourceUrl   String
  source      String
  role        String?
  stage       String?
  geography   String?
  postedAt    DateTime
}

model GithubRepo {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String   @unique
  stars       Int
  language    String?
  topics String
  owner       String
  fetchedAt   DateTime @default(now())
}

model DigestSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  geography String?  // which region's digest they want
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}
