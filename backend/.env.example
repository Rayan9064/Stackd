# Required. Local dev uses SQLite relative to backend/models/schema.prisma.
DATABASE_URL="file:./dev.db"

# Required in production if you want digest emails to send. App still runs without it.
RESEND_API_KEY=""

# Optional. Must be a verified Resend sender/domain when sending real email.
RESEND_FROM_EMAIL="digest@example.com"

# Optional. Product Hunt developer token. Fetcher skips when blank.
PH_API_KEY=""

# Optional. Reddit app credentials from https://www.reddit.com/prefs/apps. Fetcher uses public endpoints or skips failures when blank.
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Optional. GitHub token for higher search API rate limits.
GITHUB_TOKEN=""

# Required for browsers. Comma-separated frontend origins allowed by FastAPI CORS.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-domain.vercel.app"
