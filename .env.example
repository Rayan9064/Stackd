# Backend: required. Local dev uses SQLite relative to backend/models/schema.prisma.
# Production can use a Railway Postgres connection string.
DATABASE_URL="file:./dev.db"

# Backend: required only for sending digest emails. App still works when blank.
RESEND_API_KEY=""

# Backend: optional verified sender for Resend.
RESEND_FROM_EMAIL="digest@example.com"

# Backend: optional Product Hunt developer token. Fetcher skips when blank.
PH_API_KEY=""

# Backend: optional Reddit app credentials. Fetcher uses public endpoints or skips failures when blank.
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Backend: optional GitHub token for higher rate limits.
GITHUB_TOKEN=""

# Backend: required for browser requests.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-domain.vercel.app"

# Frontend: required. Local FastAPI URL; production should be your Railway backend URL.
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"
