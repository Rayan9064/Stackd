# Database connection
# For production (PostgreSQL): postgresql://user:password@host:port/dbname
# For local development (SQLite): file:./dev.db
DATABASE_URL="file:./dev.db"

# Email Delivery (Resend SDK)
# Obtain this from https://resend.com
RESEND_API_KEY="re_123456789"
# The sender email address (e.g. digest@stackd.in or a verified domain on Resend)
RESEND_FROM_EMAIL="digest@yourdomain.com"

# Product Hunt Scraper (Optional)
# Create a developer account on Product Hunt to obtain a token
PH_API_KEY=""

# Reddit Scraper (Optional)
# Create a Reddit app (script type) on https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Backend API URL (for Frontend Next.js integration)
NEXT_PUBLIC_API_URL="http://localhost:8000"
